# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Expo ────────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ─── Native builds (generated by EAS / expo prebuild) ─────────────────────
/ios/
/android/
.kotlin/

# ─── Native signing & certificates ────────────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
google-services.json
GoogleService-Info.plist

# ─── EAS secrets (contains project credentials, never commit) ─────────────
credentials.json

# ─── Environment variables ────────────────────────────────────────────────
.env
.env.*
.env*.local
!.env.example

# ─── Metro ───────────────────────────────────────────────────────────────
.metro-health-check*

# ─── Debug logs ──────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*

# ─── OS artefacts ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── TypeScript build cache ───────────────────────────────────────────────
*.tsbuildinfo

# ─── Test & coverage output ──────────────────────────────────────────────
coverage/
.nyc_output/

# ─── IDE configs (keep VS Code shared settings, skip personal overrides) ──
.idea/
*.swp
*.swo

# ─── Expo reset-project scaffolding ──────────────────────────────────────
app-example/

# ─── Local SQLite database (user data, never commit) ─────────────────────
*.db
*.db-wal
*.db-shm
